# qm-code-runner configuration
# Copy this file to .env and adjust values as needed.

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Execution Defaults
DEFAULT_TIMEOUT=30
MAX_TIMEOUT=300
DEFAULT_MEMORY=256m
MAX_MEMORY_MB=2048
DEFAULT_CPU_SHARES=512
MAX_CPU_CORES=4.0
DEFAULT_DISK=512m
MAX_DISK_MB=5000

# Docker
DOCKER_SOCKET=/var/run/docker.sock

# Security (uncomment to enable authentication)
# CODE_RUNNER_API_KEYS=key1,key2,key3
# AUTH_TOKEN=your-bearer-token

# Cleanup
CLEANUP_INTERVAL_HOURS=24
CLEANUP_MAX_AGE_DAYS=7
